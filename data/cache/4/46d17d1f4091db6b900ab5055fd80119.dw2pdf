<div class="level2">
<div class="table sectionedit8"><table class="inline">
	<thead>
	<tr class="row0">
		<th class="col0 leftalign"> Airport   </th><th class="col1 leftalign"> Transition Altitude   </th><th class="col2"> Transition Level (If Fixed) </th>
	</tr>
	</thead>
	<tr class="row1">
		<td class="col0 leftalign"> <a href="/dnaa" class="wikilink2" title="dnaa" rel="nofollow" data-wiki-id="dnaa">DNAA</a>  </td><td class="col1 leftalign"> 5000 ft               </td><td class="col2"> FL 065 </td>
	</tr>
	<tr class="row2">
		<td class="col0 leftalign"> <a href="/dnai" class="wikilink2" title="dnai" rel="nofollow" data-wiki-id="dnai">DNAI</a>  </td><td class="col1 leftalign"> 3500 ft               </td><td class="col2"> FL 050 </td>
	</tr>
	<tr class="row3">
