	</tr>
	<tr class="row4">
		<td class="col0 leftalign"> <a href="/dnbc" class="wikilink2" title="dnbc" rel="nofollow" data-wiki-id="dnbc">DNBC</a>  </td><td class="col1 leftalign"> 5000 ft               </td><td class="col2"> FL 065 </td>
	</tr>
	<tr class="row5">
		<td class="col0 leftalign"> <a href="/dnbe" class="wikilink2" title="dnbe" rel="nofollow" data-wiki-id="dnbe">DNBE</a>  </td><td class="col1 leftalign"> 3500 ft               </td><td class="col2"> FL 050 </td>
	</tr>
	<tr class="row6">
		<td class="col0 leftalign"> <a href="/dnbk" class="wikilink2" title="dnbk" rel="nofollow" data-wiki-id="dnbk">DNBK</a>  </td><td class="col1 leftalign"> 5000 ft               </td><td class="col2"> FL 065 </td>
	</tr>
	<tr class="row7">
		<td class="col0 leftalign"> <a href="/dnca" class="wikilink2" title="dnca" rel="nofollow" data-wiki-id="dnca">DNCA</a>  </td><td class="col1 leftalign"> 5000 ft               </td><td class="col2"> FL 065 </td>
	</tr>
	<tr class="row8">
		<td class="col0 leftalign"> <a href="/dnds" class="wikilink2" title="dnds" rel="nofollow" data-wiki-id="dnds">DNDS</a>  </td><td class="col1 leftalign"> 5000 ft               </td><td class="col2"> FL 065 </td>
