i:0;s:18:"Clearance Delivery";i:1;i:4;i:2;i:592;}i:2;i:592;}i:24;a:3:{i:0;s:12:"section_open";i:1;a:1:{i:0;i:4;}i:2;i:592;}i:25;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:592;}i:26;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:168:"* GOBD does not have a real world Delivery position but one has been created on VATSIM, particularly for busy events. If offline, contact Ground for Delivery Clearance.";}i:2;i:620;}i:27;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:788;}i:28;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:788;}i:29;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:97:"* When requesting IFR clearance, please provide your Aircraft Type, Stand Number and ATIS letter.";}i:2;i:790;}i:30;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:887;}i:31;a:3:{i:0;s:13:"section_close";i:1;a:0:{}i:2;i:889;}i:32;a:3:{i:0;s:6:"header";i:1;a:3:{i:0;s:20:"Departure Procedures";i:1;i:4;i:2;i:889;}i:2;i:889;}i:33;a:3:{i:0;s:12:"section_open";i:1;a:1:{i:0;i:4;}i:2;i:889;}i:34;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:889;}i:35;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:188:"* GOBD does not have structured departure procedures (SIDs) so you are expected to maintain runway heading until further instructions. Do not deviate from the runway heading after takeoff.";}i:2;i:919;}i:36;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1107;}i:37;a:3:{i:0;s:13:"section_close";i:1;a:0:{}i:2;i:1110;}i:38;a:3:{i:0;s:6:"header";i:1;a:3:{i:0;s:16:"Arrival Briefing";i:1;i:3;i:2;i:1110;}i:2;i:1110;}i:39;a:3:{i:0;s:12:"section_open";i:1;a:1:{i:0;i:3;}i:2;i:1110;}i:40;a:3:{i:0;s:13:"section_close";i:1;a:0:{}i:2;i:1138;}i:41;a:3:{i:0;s:6:"header";i:1;a:3:{i:0;s:23:"Arrivals and Approaches";i:1;i:4;i:2;i:1138;}i:2;i:1138;}i:42;a:3:{i:0;s:12:"section_open";i:1;a:1:{i:0;i:4;}i:2;i:1138;}i:43;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1138;}i:44;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:139:" * As your flight is approaching GOBD, you should make yourself familiar with the existing Arrivals (STARs), Holding Points and Approaches.";}i:2;i:1171;}i:45;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1310;}i:46;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1310;}i:47;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:203:" * Be aware that GOBD has 3 distinct sets of ILS Approaches (X, Y and Z) and that they have distinct approach procedures. Controllers will inform you what Approach to expect based on an assigned Arrival.";}i:2;i:1312;}i:48;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1515;}i:49;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1515;}i:50;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:88:" * GOBD is a single runway airport, so during Arrival Events, you should expect to Hold.";}i:2;i:1517;}i:51;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1605;}i:52;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1605;}i:53;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:129:" * In case of Missed Approach, climb 3000 ft and maintain runway heading. You'll receive further instructions by the Controllers.";}i:2;i:1607;}i:54;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1736;}i:55;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1736;}i:56;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:202:" * During busy events, expect to vacate right on A3 if landing 01 or vacate left on A5 if landing 19. You might be requested by Tower to continue taxi after vacating the runway. Follow the instructions.";}i:2;i:1738;}i:57;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:1940;}i:58;a:3:{i:0;s:13:"section_close";i:1;a:0:{}i:2;i:1942;}i:59;a:3:{i:0;s:6:"header";i:1;a:3:{i:0;s:29:"Parking and Ground Operations";i:1;i:4;i:2;i:1942;}i:2;i:1942;}i:60;a:3:{i:0;s:12:"section_open";i:1;a:1:{i:0;i:4;}i:2;i:1942;}i:61;a:3:{i:0;s:6:"p_open";i:1;a:0:{}i:2;i:1942;}i:62;a:3:{i:0;s:5:"cdata";i:1;a:1:{i:0;s:361:"* GOBD has plenty of parking positions across multiple aprons. Initial aircraft may be offered the Main Terminal Apron whilst subsequent aircraft will be directed to adjacent Aprons. There is limited parking availability at the Cargo Apron and due to its location on the airfield, you may be requested to taxi to a different parking position during busy events.";}i:2;i:1981;}i:63;a:3:{i:0;s:7:"p_close";i:1;a:0:{}i:2;i:2342;}i:64;a:3:{i:0;s:6:"plugin";i:1;a:4:{i:0;s:15:"include_include";i:1;a:6:{i:0;s:4:"page";i:1;s:9:"go-footer";i:2;s:4:"gobd";i:3;a:1:{i:0;s:0:"";}i:4;i:4;i:5;i:2345;}i:2;i:5;i:3;s:23:"{{page>go-footer#GOBD}}";}i:2;i:2345;}i:65;a:3:{i:0;s:13:"section_close";i:1;a:0:{}i:2;i:2368;}i:66;a:3:{i:0;s:12:"document_end";i:1;a:0:{}i:2;i:2368;}}